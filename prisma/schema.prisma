generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  avatar      String?
  bio         String?
  nickname    String?
  tag         String?
  tumbaCoins  Int      @default(100)
  status      String   @default("")
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  firebaseUid String?  @unique

  // Active group context
  activeGroupId String?
  activeGroup   Group?  @relation("ActiveGroup", fields: [activeGroupId], references: [id], onDelete: SetNull)

  entries               Entry[]
  dictionaryEntries     DictionaryEntry[]
  dictionaryComments    DictionaryComment[]
  dictionaryRatings     DictionaryRating[]
  events                Event[]
  eventPollVotes        EventPollVote[]
  eventRsvps            EventRsvp[]
  betsCreated           Bet[]
  wagers                Wager[]
  media                 Media[]
  albums                Album[]
  purchases             Purchase[]
  activityLogs          ActivityLog[]
  notificationsReceived Notification[]       @relation("notificationsReceived")
  notificationsSent     Notification[]       @relation("notificationsSent")
  monthlyAchievements   MonthlyAchievement[]
  coinTransactions      CoinTransaction[]
  shopItemsCreated      ShopItem[]           @relation("ShopItemsCreated")
  shopSuggestions       ShopSuggestion[]
  shopSuggestionVotes   ShopSuggestionVote[]

  // Group system
  groupsCreated     Group[]            @relation("GroupCreator")
  groupMemberships  GroupMembership[]
  groupJoinRequests GroupJoinRequest[]

  // Social
  stories           Story[]
  storyViews        StoryView[]
  mediaLikes        MediaLike[]
  mediaComments     MediaComment[]
}

// === GROUP SYSTEM ===

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  avatar      String?
  privacy     String   @default("OPEN") // OPEN or CLOSED
  inviteCode  String   @unique
  createdById String
  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships  GroupMembership[]
  joinRequests GroupJoinRequest[]
  activeUsers  User[]             @relation("ActiveGroup")

  // Content scoped to this group (for future per-group data)
  entries          Entry[]
  events           Event[]
  bets             Bet[]
  albums           Album[]
  media            Media[]
  dictionaryEntries DictionaryEntry[]
  activityLogs     ActivityLog[]
  stories          Story[]
  shopItems        ShopItem[]
  notifications    Notification[]

  @@index([inviteCode])
  @@index([createdById])
}

model GroupMembership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // ADMIN, MEMBER (extensible: MODERATOR, etc.)
  joinedAt  DateTime @default(now())

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
}

model GroupJoinRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  message   String?  // optional message from the requester
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, groupId])
  @@index([groupId, status])
}

model Entry {
  id        String   @id @default(cuid())
  content   String
  title     String   @default("")
  imageUrl  String?
  tags      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  month     Int
  year      Int
  createdAt DateTime @default(now())

  @@index([month, year])
  @@index([groupId])
}

model MonthlySummary {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  summary   String
  committed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([month, year])
}

model DictionaryEntry {
  id         String   @id @default(cuid())
  term       String
  definition String
  example    String?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  groupId    String?
  group      Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comments DictionaryComment[]
  ratings  DictionaryRating[]

  @@index([term])
  @@index([groupId])
}

model DictionaryComment {
  id                String          @id @default(cuid())
  content           String
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  dictionaryEntryId String
  dictionaryEntry   DictionaryEntry @relation(fields: [dictionaryEntryId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
}

model DictionaryRating {
  id                String          @id @default(cuid())
  value             Int
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  dictionaryEntryId String
  dictionaryEntry   DictionaryEntry @relation(fields: [dictionaryEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, dictionaryEntryId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String?
  category    String   @default("other")
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  polls EventPoll[]
  rsvps EventRsvp[]

  @@index([groupId])
}

model EventRsvp {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status  String // GOING, MAYBE, NOT_GOING

  @@unique([userId, eventId])
}

model EventPoll {
  id       String @id @default(cuid())
  question String
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  options EventPollOption[]
}

model EventPollOption {
  id     String    @id @default(cuid())
  text   String
  pollId String
  poll   EventPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  votes EventPollVote[]
}

model EventPollVote {
  id       String          @id @default(cuid())
  userId   String
  user     User            @relation(fields: [userId], references: [id])
  optionId String
  option   EventPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([userId, optionId])
}

// === TUMBA MARKET (Betting) ===

model Bet {
  id               String   @id @default(cuid())
  title            String
  description      String
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  groupId          String?
  group            Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  closingDate      DateTime
  status           String   @default("OPEN") // OPEN, CLOSED, RESOLVED
  resolvedOptionId String?
  createdAt        DateTime @default(now())

  options BetOption[]

  @@index([groupId])
}

model BetOption {
  id    String @id @default(cuid())
  text  String
  betId String
  bet   Bet    @relation(fields: [betId], references: [id], onDelete: Cascade)

  wagers Wager[]
}

model Wager {
  id          String    @id @default(cuid())
  amount      Int
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  betOptionId String
  betOption   BetOption @relation(fields: [betOptionId], references: [id], onDelete: Cascade)
  payout      Int?
  createdAt   DateTime  @default(now())

  @@unique([userId, betOptionId])
}

// === SHARED ALBUM (Posts) ===

model Album {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  media Media[]

  @@index([groupId])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  type      String   @default("image") // image, video
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  albumId   String?
  album     Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  likes     MediaLike[]
  comments  MediaComment[]

  @@index([groupId])
}

model MediaLike {
  id        String   @id @default(cuid())
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([mediaId, userId]) // אי אפשר לעשות לייק פעמיים לאותה תמונה!
}

model MediaComment {
  id        String   @id @default(cuid())
  content   String
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// === TUMBA SHOP ===

model ShopItem {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Int
  imageUrl    String?
  category    String   @default("general")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Provenance: ADMIN = created via admin panel, BUILT_IN = seeded, COMMUNITY = promoted from an approved suggestion
  source       String  @default("ADMIN")
  builtInKey   String? @unique
  createdById  String?
  createdBy    User?   @relation("ShopItemsCreated", fields: [createdById], references: [id])
  suggestionId String? @unique
  suggestion   ShopSuggestion? @relation("ApprovedShopItem", fields: [suggestionId], references: [id])
  groupId      String?
  group        Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  purchases Purchase[]

  @@index([groupId])
}

/// Community-suggested shop item awaiting group approval via thumbs up/down votes.
model ShopSuggestion {
  id             String   @id @default(cuid())
  title          String
  description    String
  price          Int
  category       String   @default("general")
  imageUrl       String?
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  creatorId      String
  creator        User     @relation(fields: [creatorId], references: [id])
  expiresAt      DateTime
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  votes        ShopSuggestionVote[]
  approvedItem ShopItem?            @relation("ApprovedShopItem")

  @@index([status])
  @@index([creatorId])
  @@index([expiresAt])
}

model ShopSuggestionVote {
  id           String         @id @default(cuid())
  suggestionId String
  suggestion   ShopSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  value        Int // +1 for upvote, -1 for downvote
  createdAt    DateTime       @default(now())

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

model Purchase {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  shopItemId String
  shopItem   ShopItem @relation(fields: [shopItemId], references: [id])
  price      Int // price at time of purchase
  createdAt  DateTime @default(now())
}

// === NOTIFICATIONS ===

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  recipient   User     @relation("notificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User     @relation("notificationsSent", fields: [actorId], references: [id], onDelete: Cascade)
  type        String // BET, EVENT, HIGHLIGHT, GROUP_JOIN_REQUEST, GROUP_JOIN_APPROVED
  message     String
  targetUrl   String?
  isRead      Boolean  @default(false)
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
  @@index([groupId])
}

// === ACTIVITY LOG (hosting / car / etc.) ===

model ActivityLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  groupId        String?
  group          Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  type           String // HOST, CAR
  note           String?
  // CAR fields
  passengerCount Int? // number of passengers carried
  distanceKm     Float? // distance driven in km
  // HOST fields
  attendeeCount  Int? // number of attendees at the event
  shortNotice    Boolean  @default(false) // was this short-notice hosting?
  createdAt      DateTime @default(now())

  @@index([type])
  @@index([userId])
  @@index([createdAt])
  @@index([groupId])
}

// === MONTHLY ACHIEVEMENTS ===

/// One record per user per achievement per month. Unique constraint prevents duplicate rewards.
model MonthlyAchievement {
  id             String   @id @default(cuid())
  achievementKey String
  month          Int // 1-12
  year           Int
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  rewardCoins    Int
  metricValue    Float? // numeric value that determined the winner
  metricLabel    String? // human-readable description of metricValue
  createdAt      DateTime @default(now())

  @@unique([achievementKey, month, year, userId])
  @@index([month, year])
  @@index([userId])
}

// === COIN TRANSACTIONS ===

/// Audit log for all TumbaCoin credits (achievement rewards, etc.)
model CoinTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int // positive = credit, negative = debit
  reason    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// === STORIES (24h Ephemeral) ===

model Story {
  id        String   @id @default(cuid())
  url       String   // הקישור לתמונה או לוידאו מ-Firebase
  type      String   @default("image") // image, video
  caption   String?  // אופציונלי: טקסט על הסטורי
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  expiresAt DateTime // התאריך שבו הסטורי נעלם (בדרך כלל עכשיו + 24 שעות)

  views     StoryView[]

  @@index([expiresAt])
  @@index([userId])
  @@index([groupId])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([storyId, userId]) // מבטיח שמשתמש נספר רק פעם אחת בצפיות של סטורי ספציפי
}